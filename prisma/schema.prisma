generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  ADMIN
  SALES_SUPERVISOR
  SELLER
  GUIDE
  DRIVER
  LOGISTICS
}

enum BookingStatus {
  RESERVED
  CONFIRMED
  COMPLETED
  PAID
  CANCELLED
  NO_SHOW
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  DIGITAL_WALLET
  PAYPAL
  TRANSBANK
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  REFUNDED
  FAILED
}

enum CommissionType {
  PERCENTAGE_PER_SALE
  FIXED_PER_SALE
  GOAL_BASED
}

enum SettlementStatus {
  PENDING
  APPROVED
  PAID
  DISPUTED
}

enum ExpenseCategory {
  FUEL
  TOLLS
  MAINTENANCE
  DRIVER_PAY
  GUIDE_PAY
  MEALS
  PARKING
  OTHER
}

enum VoucherType {
  BOARDING
  COMMERCIAL
}

enum PaxType {
  ADULT
  CHILD
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  phone        String?
  documentId   String?  @map("document_id")
  role         UserRole
  isActive     Boolean  @default(true) @map("is_active")
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  commissionConfigs  CommissionConfig[]
  bookingsAsSeller   Booking[]          @relation("BookingSeller")
  bookingsAsGuide    Booking[]          @relation("BookingGuide")
  bookingsAsDriver   Booking[]          @relation("BookingDriver")
  commissions        Commission[]
  settlements        CommissionSettlement[]
  paymentsReceived   Payment[]          @relation("PaymentReceiver")
  departuresAsGuide  TourDeparture[]    @relation("DepartureGuide")
  departuresAsDriver TourDeparture[]    @relation("DepartureDriver")
  expensesPaidTo     TourExpense[]      @relation("ExpensePaidTo")
  staffSettlements   StaffExpenseSettlement[]

  @@index([role])
  @@index([isActive])
  @@map("users")
}

model CommissionConfig {
  id             String         @id @default(uuid())
  userId         String         @map("user_id")
  commissionType CommissionType @map("commission_type")
  percentage     Decimal?       @db.Decimal(5, 2)
  fixedAmount    Decimal?       @map("fixed_amount") @db.Decimal(12, 2)
  goalTarget     Decimal?       @map("goal_target") @db.Decimal(12, 2)
  goalBonus      Decimal?       @map("goal_bonus") @db.Decimal(12, 2)
  effectiveFrom  DateTime       @map("effective_from") @db.Date
  effectiveTo    DateTime?      @map("effective_to") @db.Date
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id])
  commissions Commission[]

  @@index([userId])
  @@index([userId, effectiveFrom, effectiveTo])
  @@map("commission_configs")
}

// ============================================================
// TOURS
// ============================================================

model TourCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tours Tour[]

  @@map("tour_categories")
}

model Tour {
  id              String   @id @default(uuid())
  name            String
  description     String?
  categoryId      String?  @map("category_id")
  durationMinutes Int      @map("duration_minutes")
  meetingPoint    String?  @map("meeting_point")
  meetingPointLat Decimal? @map("meeting_point_lat") @db.Decimal(10, 7)
  meetingPointLng Decimal? @map("meeting_point_lng") @db.Decimal(10, 7)
  includedItems   Json     @default("[]") @map("included_items")
  excludedItems   Json     @default("[]") @map("excluded_items")
  notes           String?
  minPax          Int      @default(1) @map("min_pax")
  maxPax          Int?     @map("max_pax")
  priceAdult      Decimal  @map("price_adult") @db.Decimal(12, 2)
  priceChild      Decimal  @default(0) @map("price_child") @db.Decimal(12, 2)
  minPriceAdult   Decimal? @map("min_price_adult") @db.Decimal(12, 2)
  minPriceChild   Decimal? @map("min_price_child") @db.Decimal(12, 2)
  directCost      Decimal  @default(0) @map("direct_cost") @db.Decimal(12, 2)
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  category      TourCategory?    @relation(fields: [categoryId], references: [id])
  images        TourImage[]
  schedules     TourSchedule[]
  blackoutDates TourBlackoutDate[]
  bookings      Booking[]
  departures    TourDeparture[]

  @@index([categoryId])
  @@index([isActive])
  @@map("tours")
}

model TourImage {
  id        String   @id @default(uuid())
  tourId    String   @map("tour_id")
  url       String
  altText   String?  @map("alt_text")
  sortOrder Int      @default(0) @map("sort_order")
  isCover   Boolean  @default(false) @map("is_cover")
  createdAt DateTime @default(now()) @map("created_at")

  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@index([tourId])
  @@map("tour_images")
}

model TourSchedule {
  id            String    @id @default(uuid())
  tourId        String    @map("tour_id")
  dayOfWeek     DayOfWeek @map("day_of_week")
  departureTime String    @map("departure_time")
  isActive      Boolean   @default(true) @map("is_active")
  validFrom     DateTime? @map("valid_from") @db.Date
  validTo       DateTime? @map("valid_to") @db.Date
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@unique([tourId, dayOfWeek, departureTime])
  @@index([tourId])
  @@map("tour_schedules")
}

model TourBlackoutDate {
  id          String   @id @default(uuid())
  tourId      String   @map("tour_id")
  blackoutDate DateTime @map("blackout_date") @db.Date
  reason      String?
  createdAt   DateTime @default(now()) @map("created_at")

  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@unique([tourId, blackoutDate])
  @@map("tour_blackout_dates")
}

// ============================================================
// VEHICLES
// ============================================================

model Vehicle {
  id          String   @id @default(uuid())
  plateNumber String   @unique @map("plate_number")
  name        String?
  capacity    Int
  vehicleType String?  @map("vehicle_type")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  bookings   Booking[]
  departures TourDeparture[]

  @@index([isActive])
  @@map("vehicles")
}

// ============================================================
// PASSENGERS (PAX)
// ============================================================

model Passenger {
  id             String   @id @default(uuid())
  firstName      String   @map("first_name")
  lastName       String   @map("last_name")
  nationality    String?
  documentType   String?  @map("document_type")
  documentNumber String?  @map("document_number")
  email          String?
  phone          String?
  dateOfBirth    DateTime? @map("date_of_birth") @db.Date
  specialNeeds   Json     @default("{}") @map("special_needs")
  notes          String?
  clientId       String?  @map("client_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  client           ClientAccount?     @relation(fields: [clientId], references: [id])
  bookingPassengers BookingPassenger[]
  vouchers          Voucher[]

  @@index([lastName, firstName])
  @@index([documentNumber])
  @@index([email])
  @@index([clientId])
  @@map("passengers")
}

// ============================================================
// BOOKINGS
// ============================================================

model Booking {
  id             String        @id @default(uuid())
  bookingNumber  Int           @unique @default(autoincrement()) @map("booking_number")
  tourId         String        @map("tour_id")
  tourDate       DateTime      @map("tour_date") @db.Date
  departureTime  String        @map("departure_time")
  pickupPoint    String?       @map("pickup_point")
  pickupLat      Decimal?      @map("pickup_lat") @db.Decimal(10, 7)
  pickupLng      Decimal?      @map("pickup_lng") @db.Decimal(10, 7)
  adultCount     Int           @default(0) @map("adult_count")
  childCount     Int           @default(0) @map("child_count")
  unitPriceAdult Decimal       @map("unit_price_adult") @db.Decimal(12, 2)
  unitPriceChild Decimal       @map("unit_price_child") @db.Decimal(12, 2)
  totalAmount    Decimal       @map("total_amount") @db.Decimal(12, 2)
  sellerId       String        @map("seller_id")
  guideId        String?       @map("guide_id")
  driverId       String?       @map("driver_id")
  vehicleId      String?       @map("vehicle_id")
  status         BookingStatus @default(RESERVED)
  cancellationReason String?   @map("cancellation_reason")
  cancelledAt    DateTime?     @map("cancelled_at")
  cancelledBy    String?       @map("cancelled_by")
  internalNotes  String?       @map("internal_notes")
  clientNotes    String?       @map("client_notes")
  checkInToken   String?       @unique @map("check_in_token")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  tour       Tour      @relation(fields: [tourId], references: [id])
  seller     User      @relation("BookingSeller", fields: [sellerId], references: [id])
  guide      User?     @relation("BookingGuide", fields: [guideId], references: [id])
  driver     User?     @relation("BookingDriver", fields: [driverId], references: [id])
  vehicle    Vehicle?  @relation(fields: [vehicleId], references: [id])

  passengers    BookingPassenger[]
  statusHistory BookingStatusHistory[]
  payments      Payment[]
  commissions   Commission[]
  vouchers      Voucher[]

  @@index([bookingNumber])
  @@index([tourId, tourDate])
  @@index([tourDate])
  @@index([status])
  @@index([sellerId])
  @@index([guideId])
  @@index([driverId])
  @@index([vehicleId])
  @@map("bookings")
}

model BookingPassenger {
  id          String   @id @default(uuid())
  bookingId   String   @map("booking_id")
  passengerId String   @map("passenger_id")
  paxType     PaxType  @default(ADULT) @map("pax_type")
  unitPrice   Decimal  @map("unit_price") @db.Decimal(12, 2)
  seatNumber  String?  @map("seat_number")
  checkedIn   Boolean  @default(false) @map("checked_in")
  checkedInAt DateTime? @map("checked_in_at")
  createdAt   DateTime @default(now()) @map("created_at")

  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  passenger Passenger @relation(fields: [passengerId], references: [id])

  @@unique([bookingId, passengerId])
  @@index([bookingId])
  @@index([passengerId])
  @@map("booking_passengers")
}

model BookingStatusHistory {
  id         String         @id @default(uuid())
  bookingId  String         @map("booking_id")
  fromStatus BookingStatus? @map("from_status")
  toStatus   BookingStatus  @map("to_status")
  changedBy  String         @map("changed_by")
  reason     String?
  createdAt  DateTime       @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId, createdAt])
  @@map("booking_status_history")
}

// ============================================================
// FINANCIAL - PAYMENTS
// ============================================================

model Payment {
  id              String        @id @default(uuid())
  bookingId       String        @map("booking_id")
  amount          Decimal       @db.Decimal(12, 2)
  paymentMethod   PaymentMethod @map("payment_method")
  status          PaymentStatus @default(PENDING)
  referenceNumber String?       @map("reference_number")
  paymentDate     DateTime      @default(now()) @map("payment_date")
  notes           String?
  receivedById    String?       @map("received_by")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  booking    Booking @relation(fields: [bookingId], references: [id])
  receivedBy User?   @relation("PaymentReceiver", fields: [receivedById], references: [id])

  @@index([bookingId])
  @@index([paymentDate])
  @@index([status])
  @@map("payments")
}

// ============================================================
// FINANCIAL - COMMISSIONS
// ============================================================

model Commission {
  id                 String   @id @default(uuid())
  bookingId          String   @map("booking_id")
  userId             String   @map("user_id")
  commissionConfigId String?  @map("commission_config_id")
  baseAmount         Decimal  @map("base_amount") @db.Decimal(12, 2)
  commissionAmount   Decimal  @map("commission_amount") @db.Decimal(12, 2)
  settlementId       String?  @map("settlement_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  booking          Booking               @relation(fields: [bookingId], references: [id])
  user             User                  @relation(fields: [userId], references: [id])
  commissionConfig CommissionConfig?     @relation(fields: [commissionConfigId], references: [id])
  settlement       CommissionSettlement? @relation(fields: [settlementId], references: [id])

  @@index([bookingId])
  @@index([userId])
  @@index([settlementId])
  @@map("commissions")
}

model CommissionSettlement {
  id               String           @id @default(uuid())
  userId           String           @map("user_id")
  periodStart      DateTime         @map("period_start") @db.Date
  periodEnd        DateTime         @map("period_end") @db.Date
  totalSales       Decimal          @map("total_sales") @db.Decimal(12, 2)
  totalCommission  Decimal          @map("total_commission") @db.Decimal(12, 2)
  status           SettlementStatus @default(PENDING)
  approvedBy       String?          @map("approved_by")
  approvedAt       DateTime?        @map("approved_at")
  paidAt           DateTime?        @map("paid_at")
  paymentReference String?          @map("payment_reference")
  notes            String?
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id])
  commissions Commission[]

  @@index([userId])
  @@index([periodStart, periodEnd])
  @@index([status])
  @@map("commission_settlements")
}

// ============================================================
// TOUR DEPARTURES & EXPENSES
// ============================================================

model TourDeparture {
  id            String   @id @default(uuid())
  tourId        String   @map("tour_id")
  departureDate DateTime @map("departure_date") @db.Date
  departureTime String   @map("departure_time")
  vehicleId     String?  @map("vehicle_id")
  guideId       String?  @map("guide_id")
  driverId      String?  @map("driver_id")
  totalPax      Int      @default(0) @map("total_pax")
  totalRevenue  Decimal  @default(0) @map("total_revenue") @db.Decimal(12, 2)
  totalCost     Decimal  @default(0) @map("total_cost") @db.Decimal(12, 2)
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tour     Tour     @relation(fields: [tourId], references: [id])
  vehicle  Vehicle? @relation(fields: [vehicleId], references: [id])
  guide    User?    @relation("DepartureGuide", fields: [guideId], references: [id])
  driver   User?    @relation("DepartureDriver", fields: [driverId], references: [id])
  expenses TourExpense[]

  @@unique([tourId, departureDate, departureTime])
  @@index([departureDate])
  @@index([tourId, departureDate])
  @@index([vehicleId])
  @@map("tour_departures")
}

model TourExpense {
  id              String          @id @default(uuid())
  tourDepartureId String          @map("tour_departure_id")
  category        ExpenseCategory
  description     String?
  amount          Decimal         @db.Decimal(12, 2)
  paidToId        String?         @map("paid_to")
  receiptUrl      String?         @map("receipt_url")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  tourDeparture TourDeparture @relation(fields: [tourDepartureId], references: [id])
  paidTo        User?         @relation("ExpensePaidTo", fields: [paidToId], references: [id])

  @@index([tourDepartureId])
  @@index([category])
  @@map("tour_expenses")
}

model StaffExpenseSettlement {
  id            String           @id @default(uuid())
  userId        String           @map("user_id")
  periodStart   DateTime         @map("period_start") @db.Date
  periodEnd     DateTime         @map("period_end") @db.Date
  totalAdvances Decimal          @default(0) @map("total_advances") @db.Decimal(12, 2)
  totalExpenses Decimal          @default(0) @map("total_expenses") @db.Decimal(12, 2)
  status        SettlementStatus @default(PENDING)
  approvedBy    String?          @map("approved_by")
  approvedAt    DateTime?        @map("approved_at")
  notes         String?
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("staff_expense_settlements")
}

// ============================================================
// VOUCHERS
// ============================================================

model Voucher {
  id             String      @id @default(uuid())
  voucherType    VoucherType @map("voucher_type")
  voucherCode    String      @unique @map("voucher_code")
  bookingId      String      @map("booking_id")
  passengerId    String?     @map("passenger_id")
  seatInfo       String?     @map("seat_info")
  boardingStatus String?     @default("PENDING") @map("boarding_status")
  scannedAt      DateTime?   @map("scanned_at")
  summaryData    Json?       @map("summary_data")
  issuedAt       DateTime    @default(now()) @map("issued_at")
  isVoid         Boolean     @default(false) @map("is_void")
  voidedAt       DateTime?   @map("voided_at")
  pdfUrl         String?     @map("pdf_url")
  createdAt      DateTime    @default(now()) @map("created_at")

  booking   Booking    @relation(fields: [bookingId], references: [id])
  passenger Passenger? @relation(fields: [passengerId], references: [id])

  @@index([bookingId])
  @@index([passengerId])
  @@index([voucherCode])
  @@map("vouchers")
}

// ============================================================
// CLIENT PORTAL
// ============================================================

model ClientAccount {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  phone         String?
  isActive      Boolean   @default(true) @map("is_active")
  emailVerified Boolean   @default(false) @map("email_verified")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  passengers Passenger[]

  @@index([email])
  @@map("client_accounts")
}
